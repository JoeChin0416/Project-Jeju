rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null && request.auth.token.email is string;
    }

    function signedInEmail() {
      return request.auth.token.email;
    }

    function isOwner() {
      return signedIn()
        && signedInEmail() == "dpluschin0416@gmail.com";
    }

    function isRetiredAccount() {
      return signedIn() && signedInEmail() == "joe.chin@joe.com.tw";
    }

    function isPasswordUser() {
      return signedIn() && request.auth.token.firebase.sign_in_provider == "password";
    }

    function isGoogleUser() {
      return signedIn() && request.auth.token.firebase.sign_in_provider == "google.com";
    }

    function accessSettingsDocument() {
      return /databases/(default)/documents/sharedTrips/jeju-2026-girls/access/default;
    }

    function accessExists() {
      return firestore.exists(accessSettingsDocument());
    }

    function settings() {
      return firestore.get(accessSettingsDocument()).data.settings;
    }

    function isAdmin() {
      return accessExists() && settings().adminEmails is list && signedInEmail() in settings().adminEmails;
    }

    function isTripMember() {
      return accessExists() && settings().memberEmails is list && signedInEmail() in settings().memberEmails;
    }

    function isWhitelistedGoogleUser() {
      return isGoogleUser() && accessExists() && settings().googleWhitelist is list && signedInEmail() in settings().googleWhitelist;
    }

    function isAllowedPasswordUser() {
      return isPasswordUser() && (isOwner() || isAdmin() || isTripMember());
    }

    function sharedTripUserIsAllowed() {
      return !isRetiredAccount()
        && (isOwner() || isAdmin() || isTripMember() || isWhitelistedGoogleUser() || isAllowedPasswordUser());
    }

    function validImageUpload() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    match /trips/{tripId}/{allPaths=**} {
      allow read: if sharedTripUserIsAllowed();
      allow delete: if isOwner() || isAdmin();
      allow create, update: if sharedTripUserIsAllowed() && validImageUpload();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
