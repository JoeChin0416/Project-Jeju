rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email is string;
    }

    function signedInEmail() {
      return request.auth.token.email;
    }

    function isOwner() {
      return signedIn() && signedInEmail() == "dpluschin0416@gmail.com";
    }

    function isPasswordUser() {
      return signedIn() && request.auth.token.firebase.sign_in_provider == "password";
    }

    function isGoogleUser() {
      return signedIn() && request.auth.token.firebase.sign_in_provider == "google.com";
    }

    function accessSettingsDocument() {
      return /databases/$(database)/documents/sharedTrips/jeju-2026-girls/access/default;
    }

    function accessExists() {
      return exists(accessSettingsDocument());
    }

    function settings() {
      return get(accessSettingsDocument()).data.settings;
    }

    function isAdmin() {
      return accessExists() && settings().adminEmails is list && signedInEmail() in settings().adminEmails;
    }

    function isTripMember() {
      return accessExists() && settings().memberEmails is list && signedInEmail() in settings().memberEmails;
    }

    function isWhitelistedGoogleUser() {
      return isGoogleUser() && accessExists() && settings().googleWhitelist is list && signedInEmail() in settings().googleWhitelist;
    }

    function isAllowedPasswordUser() {
      return isPasswordUser() && (isOwner() || isAdmin() || isTripMember());
    }

    function sharedTripUserIsAllowed() {
      return isOwner() || isAdmin() || isTripMember() || isWhitelistedGoogleUser() || isAllowedPasswordUser();
    }

    match /sharedTrips/jeju-2026-girls/access/default {
      allow read: if signedIn();
      allow create: if isOwner();
      allow update, delete: if sharedTripUserIsAllowed();
    }

    match /sharedTrips/jeju-2026-girls/stores/default {
      allow read, create, update: if sharedTripUserIsAllowed();
      allow delete: if false;
    }

    match /users/{uid}/{document=**} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
